<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.ContratacaoHospedagem"
             Title="Reserva"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F8FAFC">
    <ScrollView>
        <VerticalStackLayout VerticalOptions="CenterAndExpand" Padding="24" Spacing="20">

            <VerticalStackLayout Spacing="4" HorizontalOptions="Center" Margin="0,0,0,10">
                <Label Text="GRAND HOTEL"
                       FontFamily="Kalam"
                       FontSize="36"
                       FontAttributes="Bold"
                       TextColor="#0F766E" HorizontalTextAlignment="Center" />
                <Label Text="Configure sua estadia ideal"
                       FontSize="13"
                       TextColor="#64748B"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <Border StrokeShape="RoundRectangle 12" BackgroundColor="#FFFFFF" Stroke="#E2E8F0" StrokeThickness="1" Padding="16">
                <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, *, Auto" RowSpacing="16">

                    <Label Grid.Row="0" Grid.Column="0" Text="Adultos" TextColor="#1E293B" FontAttributes="Bold" VerticalOptions="Center" FontSize="15"/>
                    <Label Grid.Row="0" Grid.Column="1" TextColor="#0F766E" FontAttributes="Bold" FontSize="16" VerticalOptions="Center"
                           Text="{Binding Value}" BindingContext="{x:Reference stp_adultos}" HorizontalTextAlignment="Center"/>
                    <Stepper Grid.Row="0" Grid.Column="2" x:Name="stp_adultos" Minimum="0" Maximum="10" Increment="1" />

                    <Label Grid.Row="1" Grid.Column="0" Text="Crianças" TextColor="#1E293B" FontAttributes="Bold" VerticalOptions="Center" FontSize="15"/>
                    <Label Grid.Row="1" Grid.Column="1" TextColor="#0F766E" FontAttributes="Bold" FontSize="16" VerticalOptions="Center"
                           Text="{Binding Value}" BindingContext="{x:Reference stp_criancas}" HorizontalTextAlignment="Center"/>
                    <Stepper Grid.Row="1" Grid.Column="2" x:Name="stp_criancas" Minimum="0" Maximum="10" Increment="1" />
                </Grid>
            </Border>

            <Border StrokeShape="RoundRectangle 12" BackgroundColor="#FFFFFF" Stroke="#E2E8F0" StrokeThickness="1" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Acomodação" TextTransform="Uppercase" FontSize="11" FontAttributes="Bold" TextColor="#0F766E" CharacterSpacing="1"/>
                    <Picker x:Name="pck_quarto" Title="Selecione uma suíte..." TitleColor="#94A3B8" TextColor="#1E293B" ItemDisplayBinding="{Binding Descricao}"/>
                </VerticalStackLayout>
            </Border>

            <Border StrokeShape="RoundRectangle 12" BackgroundColor="#FFFFFF" Stroke="#E2E8F0" StrokeThickness="1" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Período da Estadia" TextTransform="Uppercase" FontSize="11" FontAttributes="Bold" TextColor="#0F766E" CharacterSpacing="1"/>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="16">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Check-in" TextColor="#64748B" FontSize="13"/>
                            <DatePicker x:Name="dtpck_checkin" DateSelected="dtpck_checkin_DateSelected" Format="dd/MM/yyyy" TextColor="#1E293B"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Check-out" TextColor="#64748B" FontSize="13"/>
                            <DatePicker x:Name="dtpck_checkout" Format="dd/MM/yyyy" TextColor="#1E293B"/>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="8" Margin="0,10,0,0">
                <Button Text="Ver Resumo da Reserva" Clicked="Button_Clicked" BackgroundColor="#0F766E" TextColor="#FFFFFF" CornerRadius="8" HeightRequest="48" FontAttributes="Bold" />
                <Button Text="Sobre o Desenvolvedor" Clicked="Button_Sobre_Clicked" BackgroundColor="Transparent" TextColor="#0F766E" FontSize="13" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
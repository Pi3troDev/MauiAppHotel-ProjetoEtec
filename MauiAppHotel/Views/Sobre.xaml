<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.Sobre"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource Gray100}">

    <VerticalStackLayout VerticalOptions="CenterAndExpand" 
                         Spacing="20" 
                         Padding="20">

        <Label Text="Sobre o App"
               FontFamily="Kalam"
               FontSize="50"
               TextColor="{StaticResource Primary}"
               HorizontalOptions="Center" />

        <Frame Padding="20" CornerRadius="10" HasShadow="True">
            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">

                <Label Text="Desenvolvedor:" FontSize="18" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                <Label Text="Pietro Alves Ferreira" FontSize="22" TextColor="{StaticResource Primary}" HorizontalTextAlignment="Center" />

                <Label Text="Ano de Desenvolvimento:" FontSize="18" FontAttributes="Bold" Margin="0,15,0,0" HorizontalTextAlignment="Center" />
                <Label Text="2026" FontSize="22" TextColor="{StaticResource Primary}" HorizontalTextAlignment="Center" />

            </VerticalStackLayout>
        </Frame>

        <Button Text="Voltar" Clicked="Button_Voltar_Clicked" />

    </VerticalStackLayout>
</ContentPage>
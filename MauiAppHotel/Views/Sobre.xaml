<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.Sobre"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F8FAFC">

    <VerticalStackLayout VerticalOptions="CenterAndExpand" Spacing="24" Padding="24">

        <Label Text="Informações" FontFamily="Kalam" FontSize="36" TextColor="#0F766E" HorizontalOptions="Center" FontAttributes="Bold" />

        <Border StrokeShape="RoundRectangle 12" BackgroundColor="#FFFFFF" Stroke="#E2E8F0" StrokeThickness="1" Padding="24">
            <VerticalStackLayout Spacing="16">

                <VerticalStackLayout Spacing="2">
                    <Label Text="Desenvolvido por" FontSize="12" TextColor="#64748B" TextTransform="Uppercase" CharacterSpacing="1" />
                    <Label Text="Pietro Alves Ferreira" FontSize="20" FontAttributes="Bold" TextColor="#1E293B" />
                </VerticalStackLayout>

                <BoxView HeightRequest="1" BackgroundColor="#E2E8F0" />

                <VerticalStackLayout Spacing="2">
                    <Label Text="Ano de Lançamento" FontSize="12" TextColor="#64748B" TextTransform="Uppercase" CharacterSpacing="1" />
                    <Label Text="2026" FontSize="18" FontAttributes="Bold" TextColor="#0F766E" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </Border>

        <Button Text="Voltar para Home" Clicked="Button_Voltar_Clicked" BackgroundColor="#1E293B" TextColor="#FFFFFF" CornerRadius="8" HeightRequest="48" />

    </VerticalStackLayout>
</ContentPage>
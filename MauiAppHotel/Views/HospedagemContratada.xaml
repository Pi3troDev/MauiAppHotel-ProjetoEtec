<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.HospedagemContratada"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F8FAFC">

    <VerticalStackLayout VerticalOptions="CenterAndExpand" Padding="24" Spacing="20">

        <Label Text="Confirmação da Reserva" TextColor="#64748B" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" TextTransform="Uppercase" CharacterSpacing="1"/>

        <Border StrokeShape="RoundRectangle 16" BackgroundColor="#FFFFFF" Stroke="#E2E8F0" StrokeThickness="1" Padding="24">
            <VerticalStackLayout Spacing="16">

                <Label Text="{Binding QuartoSelecionado.Descricao}" TextColor="#1E293B" FontFamily="Kalam" FontSize="28" FontAttributes="Bold" HorizontalTextAlignment="Center"/>

                <BoxView HeightRequest="1" BackgroundColor="#E2E8F0" />

                <Grid ColumnDefinitions="*, *">
                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                        <Label Text="Adultos" TextColor="#64748B" FontSize="13" HorizontalTextAlignment="Center"/>
                        <Label Text="{Binding QntAdultos}" TextColor="#1E293B" FontAttributes="Bold" FontSize="16" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                        <Label Text="Crianças" TextColor="#64748B" FontSize="13" HorizontalTextAlignment="Center"/>
                        <Label Text="{Binding QntCriancas}" TextColor="#1E293B" FontAttributes="Bold" FontSize="16" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Grid>

                <BoxView HeightRequest="1" BackgroundColor="#E2E8F0" />

                <Grid ColumnDefinitions="*, *, *">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="Check-in" TextColor="#64748B" FontSize="12" HorizontalTextAlignment="Center"/>
                        <Label Text="{Binding DataCheckIn, StringFormat='{}{0:dd/MM/yyyy}'}" TextColor="#1E293B" FontSize="14" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                        <Label Text="Check-out" TextColor="#64748B" FontSize="12" HorizontalTextAlignment="Center"/>
                        <Label Text="{Binding DataCheckOut, StringFormat='{}{0:dd/MM/yyyy}'}" TextColor="#1E293B" FontSize="14" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="2" Spacing="2">
                        <Label Text="Diárias" TextColor="#64748B" FontSize="12" HorizontalTextAlignment="Center"/>
                        <Label Text="{Binding Estadia}" TextColor="#0F766E" FontSize="14" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Grid>

                <BoxView HeightRequest="1" BackgroundColor="#E2E8F0" />

                <VerticalStackLayout Spacing="4" Margin="0,8,0,0">
                    <Label Text="Total a pagar" TextColor="#64748B" HorizontalTextAlignment="Center" FontSize="13"/>
                    <Label Text="{Binding ValorTotal, StringFormat='{}{0:C}'}" TextColor="#15803D" FontAttributes="Bold" FontSize="32" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </Border>

        <Button Text="Voltar e Ajustar" Clicked="Button_Clicked" BackgroundColor="#64748B" TextColor="#FFFFFF" CornerRadius="8" HeightRequest="48" />

    </VerticalStackLayout>
</ContentPage>